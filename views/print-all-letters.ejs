                    <% 
                    let autoRating = '';
                    if (internship.grade === 'O' || internship.grade === 'A+') autoRating = '5';
                    else if (internship.grade === 'A') autoRating = '4';
                    else if (internship.grade === 'B+') autoRating = '4';
                    else if (internship.grade) autoRating = '3';
                    %>
                    <tr>
                        <td><strong>1. Technical Skills & Knowledge</strong><br><span
                                style="font-size:12px;color:#555;">Ability to apply technical knowledge to assigned
                                tasks.</span></td>
