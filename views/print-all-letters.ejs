                        <td class="rating-col"><%= autoRating %></td>
                    </tr>
                    <tr>
                        <td><strong>6. Professionalism & Attitude</strong><br><span
                                style="font-size:12px;color:#555;">Reliability, punctuality, and responsiveness to
