                        <td class="rating-col"><%= autoRating %></td>
                    </tr>
                    <tr>
                        <td><strong>7. Teamwork & Collaboration</strong><br><span
                                style="font-size:12px;color:#555;">Ability to work effectively with team members.</span>
                        </td>
                        <td class="rating-col"><%= autoRating %></td>
                    </tr>
                </tbody>
            </table>
        </div>

